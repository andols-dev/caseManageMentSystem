@using Microsoft.AspNetCore.Identity
@using caseManageMentSystem.Areas.Admin.Models
@using caseManageMentSystem.Enums
@using caseManageMentSystem.Models
@model EditUserVM
@{
    ViewData["Title"] = "Edit User";
}

<div
    class="mx-auto max-w-3xl space-y-8 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-8 shadow-2xl shadow-slate-950/20">
    <div class="text-center">
        <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Admin</p>
        <h1 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Edit user account</h1>
    </div>

    <div class="rounded-[1.75rem] border border-slate-800/80 bg-slate-950/80 p-6 sm:p-8">
        <form asp-action="Edit" asp-controller="User" method="post" class="space-y-6">
            <div class="grid gap-4 sm:grid-cols-2">
                <input asp-for="Id" type="hidden" />
                <label class="space-y-2 block">
                    <span class="text-sm font-medium text-slate-200">First name</span>
                    <input asp-for="FirstName" type="text" value="@Model.FirstName"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="FirstName" class="text-sm text-rose-300"></span>
                </label>

                <label class="space-y-2 block">
                    <span class="text-sm font-medium text-slate-200">Last name</span>
                    <input asp-for="LastName" type="text"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="LastName" class="text-sm text-rose-300"></span>
                </label>
            </div>

            <label class="space-y-2 block">
                <span class="text-sm font-medium text-slate-200">Email address</span>
                <input asp-for="Email" type="email"
                       class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                <span asp-validation-for="Email" class="text-sm text-rose-300"></span>
            </label>



            <label class="space-y-2 block">
                <span class="text-sm font-medium text-slate-200">Role</span>
                <select asp-for="Role"
                        class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20">
                    <option value="admin">Admin</option>
                    <option value="caseManager">Case Manager</option>
                    <option value="client">Client</option>
                </select>
                <span asp-validation-for="Role" class="text-sm text-rose-300"></span>
            </label>


            <button type="submit"
                    class="cursor-pointer cursor-hover inline-flex w-full items-center justify-center rounded-full bg-cyan-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/80 ">
                Edit account
            </button>
        </form>
    </div>
</div>

