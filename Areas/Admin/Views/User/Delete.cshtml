@model ApplicationUser
@{
    ViewData["Title"] = "Delete User";
}

<div
    class="mx-auto max-w-3xl space-y-8 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-8 shadow-2xl shadow-slate-950/20">
    <div class="text-center">
        <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Admin</p>
        <h1 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Delete user account</h1>
        <p class="mt-3 text-sm text-slate-400">Confirm this action to permanently remove the user.</p>
    </div>

    <div class="rounded-[1.75rem] border border-slate-800/80 bg-slate-950/80 p-6 sm:p-8">
        @if (Model == null)
        {
            <div class="space-y-4 text-center">
                <p class="text-lg font-semibold text-white">User not found</p>
                <p class="text-sm text-slate-400">The user may already have been deleted or the ID is invalid.</p>
                <a asp-action="Index" asp-controller="User"
                       class="inline-flex items-center justify-center rounded-full border border-slate-700 bg-slate-900 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-slate-500 hover:text-white">Back
                    to users</a>
                </div>
            }
        else
            {
                <form asp-action="DeleteConfirmed" asp-controller="User" method="post" class="space-y-6">
                    <input asp-for="Id" type="hidden" />

                    <div class="space-y-4 rounded-3xl border border-slate-800/80 bg-slate-900 p-6">
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <p class="text-sm uppercase tracking-[0.32em] text-slate-400">Username</p>
                                <p class="mt-2 text-base font-semibold text-white">@Model.UserName</p>
                            </div>
                            <div>
                                <p class="text-sm uppercase tracking-[0.32em] text-slate-400">Email</p>
                                <p class="mt-2 text-base font-semibold text-white">@Model.Email</p>
                            </div>
                            <div>
                                <p class="text-sm uppercase tracking-[0.32em] text-slate-400">First name</p>
                                <p class="mt-2 text-base font-semibold text-white">@Model.FirstName</p>
                            </div>
                            <div>
                                <p class="text-sm uppercase tracking-[0.32em] text-slate-400">Last name</p>
                                <p class="mt-2 text-base font-semibold text-white">@Model.LastName</p>
                            </div>
                        </div>
                    </div>

                    <div class="rounded-3xl border border-rose-500/20 bg-rose-500/5 p-4">
                        <p class="text-sm font-medium uppercase tracking-[0.24em] text-rose-300">Danger zone</p>
                        <p class="mt-2 text-sm leading-6 text-slate-300">Deleting this user is permanent. All associated access
                            rights will be removed immediately.</p>
                        </div>

                        <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
                            <a asp-action="Index" asp-controller="User"
                               class="inline-flex items-center justify-center rounded-full border border-slate-700 bg-slate-900 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-slate-500 hover:text-white">Cancel</a>

                            <button type="submit"
                                    class="inline-flex items-center justify-center rounded-full bg-rose-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-rose-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-400/80">Delete
                                permanently</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
