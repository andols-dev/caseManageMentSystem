@using caseManageMentSystem.Areas.Admin.Models
@using caseManageMentSystem.Enums
@using caseManageMentSystem.Models
@model CreateUserVM
@{
    ViewData["Title"] = "Create User";
}

<h2>Create User</h2>

<div class="min-h-[calc(100vh-6rem)] flex items-center justify-center py-12">
    <div
        class="w-full max-w-2xl space-y-8 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-8 shadow-2xl shadow-slate-950/20">
        <div class="text-center">
            <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Create User</p>
            <h1 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Create user account</h1>
          
        </div>

        <div class="rounded-[1.75rem] border border-slate-800/80 bg-slate-950/80 p-6 sm:p-8">
            <form asp-action="Create" asp-controller="User" method="post" class="space-y-6">
                <div class="grid gap-4 sm:grid-cols-2">
                    <label class="space-y-2">
                        <span class="text-sm font-medium text-slate-200">First name</span>
                        <input asp-for="FirstName"
                               class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                        <span asp-validation-for="FirstName" class="text-sm text-rose-300"></span>
                    </label>

                    <label class="space-y-2">
                        <span class="text-sm font-medium text-slate-200">Last name</span>
                        <input asp-for="LastName"
                               class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                        <span asp-validation-for="LastName" class="text-sm text-rose-300"></span>
                    </label>
                </div>

                <label class="space-y-2">
                    <span class="text-sm font-medium text-slate-200">Email address</span>
                    <input asp-for="Email"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="Email" class="text-sm text-rose-300"></span>
                </label>

                <label class="space-y-2">
                    <span class="text-sm font-medium text-slate-200">Password</span>
                    <input asp-for="Password"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="Password" class="text-sm text-rose-300"></span>
                </label>

                <select asp-for="Role"
                        class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20">
                    <option value="admin">Admin</option>
                    <option value="caseManager">Case Manager</option>
                    <option value="client">Client</option>
                </select>
                  
            </label>

            <button type="submit"
                    class="inline-flex w-full items-center justify-center rounded-full bg-cyan-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/80">Create
                account</button>
            </form>
        </div>

        <p class="text-center text-sm text-slate-400">Already have an account? <a href="#"
                                                                                      class="font-semibold text-white transition hover:text-cyan-300">Sign in</a></p>
        </div>
    </div>
