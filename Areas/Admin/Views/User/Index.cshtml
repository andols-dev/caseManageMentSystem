@model IList<UserVM>
@{
    ViewData["Title"] = "Users";
}

<h2>Users</h2>

<table class="table">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Roles</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.User.UserName</td>
                <td>@user.User.Email</td>
                <td>
                    @foreach (var role in user.Roles)
                    {
                        <span class="badge badge-secondary">@role</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>