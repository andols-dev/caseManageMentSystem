@model PagedResult<UserVM>
@{
    ViewData["Title"] = "Users";
}

<div class="space-y-6">
    <div
        class="flex flex-col gap-4 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-6 shadow-2xl shadow-slate-950/20 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Admin</p>
            <h1 class="mt-2 text-3xl font-semibold text-white">Users</h1>
            <p class="mt-2 text-sm text-slate-400">Manage user accounts and roles.</p>
        </div>

        <a asp-action="Create"
           class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">Create
            New User</a>
        </div>

        <div
            class="overflow-hidden rounded-[2rem] border border-slate-800/80 bg-slate-900/95 shadow-2xl shadow-slate-950/20">
            <table class="min-w-full divide-y divide-slate-800 text-sm">
                <thead class="bg-slate-950/80">
                    <tr>
                        <th class="px-5 py-4 text-left font-semibold uppercase tracking-[0.14em] text-slate-400">Username
                        </th>
                        <th class="px-5 py-4 text-left font-semibold uppercase tracking-[0.14em] text-slate-400">Email</th>
                        <th class="px-5 py-4 text-left font-semibold uppercase tracking-[0.14em] text-slate-400">Role</th>
                        <th class="w-24 px-5 py-4"><b>Actions</b></th>
                        <th class="w-24 px-5 py-4"></th>
                        <th class="w-24 px-5 py-4"></th>
                        <th class="w-24 px-5 py-4"></th>
                        <th class="w-24 px-5 py-4"></th>
                        <th class="w-24 px-5 py-4"></th>
                        <th class="w-24 px-5 py-4"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800 bg-slate-900">
                    @if (Model.Items.Count() == 0)
                    {
                        <tr>
                            <td colspan="4" class="px-5 py-8 text-center text-sm text-slate-400">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Items)
                        {
                            <tr class="hover:bg-slate-950/70">
                                <td class="px-5 py-4 text-slate-100">@user.User.UserName</td>
                                <td class="px-5 py-4 text-slate-100">@user.User.Email</td>
                                <td class="px-5 py-4">
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var role in user.Roles)
                                        {
                                            <span
                                            class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-slate-300">@role</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-5 py-4">
                                    <a asp-action="Delete" asp-route-id="@user.User.Id"
                                       class="text-red-500 hover:text-red-400">Delete user</a>
                                </td>
                                <td class="px-5 py-4"><a asp-action="Edit" asp-route-id="@user.User.Id">Edit User</a></td>
                                <td class="px-5 py-4"></td>
                                <td class="px-5 py-4"></td>
                                <td class="px-5 py-4"></td>
                                <td class="px-5 py-4"></td>
                                <td class="px-5 py-4"></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            <div class="flex items-center justify-between px-5 py-4 bg-slate-950/80">
                <div class="text-sm text-slate-400">Showing @Model.Items.Count() to @Model.TotalItems of @Model.TotalItems
                    users</div>
                    <div class="flex gap-2">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-route-page="@(Model.PageNumber - 1)"
                               class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-sm font-medium text-slate-300 hover:bg-slate-700">Previous</a>
                        }
                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index" asp-route-page="@(Model.PageNumber + 1)"
                               class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-sm font-medium text-slate-300 hover:bg-slate-700">Next</a>
                        }
                    </div>
                </div>

            </div>
        </div>