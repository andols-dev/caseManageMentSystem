@using Microsoft.AspNetCore.Identity
@using caseManageMentSystem.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/output.css">

        <title>Case Management System</title>
    </head>

    <body class="bg-slate-950 text-slate-100 antialiased">
        <div class="min-h-screen bg-slate-950">
            <nav class="border-b border-slate-800 bg-slate-900/95 backdrop-blur-xl">
                <div
                    class="mx-auto flex max-w-7xl flex-col gap-6 px-6 py-4 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                    <div class="flex items-center gap-10">
                        <a href="#" class="text-white text-lg font-semibold tracking-tight">Case Management System</a>
                        <div class="hidden items-center gap-6 md:flex">
                            <a href="#" class="text-slate-300 transition hover:text-white">Home</a>
                            <a href="#features" class="text-slate-300 transition hover:text-white">Features</a>
                            <a href="#" class="text-slate-300 transition hover:text-white">About</a>
                            <a href="#" class="text-slate-300 transition hover:text-white">Contact</a>
                            @if (SignInManager.IsSignedIn(User) && User.IsInRole("admin"))
                            {
                                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                                   class="text-slate-300 transition hover:text-white">Admin</a>
                            }

                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        @await Html.PartialAsync("_LoginPartial")
                        <a href="#get-started"
                               class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">Get
                            started</a>
                        </div>
                    </div>
                </nav>

                <main class="mx-auto max-w-7xl px-6 py-10 lg:px-8">
                    @RenderBody()
                </main>

                <footer class="border-t border-slate-800 bg-slate-950/90 px-6 py-6 text-slate-400 lg:px-8">
                    <div class="mx-auto flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-sm">Case Management System.</p>
                        <div class="flex flex-wrap gap-4 text-sm text-slate-400">
                            <a href="#" class="transition hover:text-white">Privacy</a>
                            <a href="#" class="transition hover:text-white">Terms</a>
                            <a href="#" class="transition hover:text-white">Support</a>
                        </div>
                    </div>
                </footer>
            </div>
        </body>

    </html>