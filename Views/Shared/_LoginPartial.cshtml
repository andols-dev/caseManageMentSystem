@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Rendering
@inject SignInManager<caseManageMentSystem.Models.ApplicationUser> SignInManager
@inject UserManager<caseManageMentSystem.Models.ApplicationUser> UserManager

<div class="flex items-center gap-4 text-sm">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="text-slate-200">Hello, @User.Identity?.Name</span>
        <form class="inline" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="text-slate-300 transition hover:text-white">Logout</button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="text-slate-300 transition hover:text-white">Login</a>
        <a asp-controller="Account" asp-action="Register" class="text-slate-300 transition hover:text-white">Register</a>
    }
</div>
