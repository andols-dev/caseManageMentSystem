@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Rendering
@inject SignInManager<caseManageMentSystem.Models.ApplicationUser> SignInManager
@inject UserManager<caseManageMentSystem.Models.ApplicationUser> UserManager

<div class="flex items-center gap-4 text-sm">
    @if (SignInManager.IsSignedIn(User))
    {
        <a asp-area=""  asp-action="UserProfile" asp-controller="Account" class="text-slate-200">Hello, @User.Identity?.Name</a>
        <form class="inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class=" cursor-pointer text-slate-300 transition hover:text-white">Logout</button>
        </form>
    }

    else
    {
        <a asp-area="" asp-controller="Account" asp-action="Login"
           class="cursor-pointer text-slate-300 transition hover:text-white">Login</a>
        <a asp-area="" asp-controller="Account" asp-action="Register"
           class="cursor-pointer text-slate-300 transition hover:text-white">Register</a>
    }
</div>
