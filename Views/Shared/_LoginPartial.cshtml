@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Rendering
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="flex items-center gap-4 text-sm">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="text-slate-200">Hello, @User.Identity?.Name</span>
        <form class="inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
            <button type="submit" class="text-slate-300 transition hover:text-white">Logout</button>
        </form>
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Login" class="text-slate-300 transition hover:text-white">Login</a>
        <a asp-area="Identity" asp-page="/Account/Register" class="text-slate-300 transition hover:text-white">Register</a>
    }
</div>
