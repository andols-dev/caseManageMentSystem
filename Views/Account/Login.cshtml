@{
    ViewData["Title"] = "Login";

}
@model caseManageMentSystem.Models.LoginUser

<div class="min-h-[calc(100vh-6rem)] flex items-center justify-center py-12">
    <div
        class="w-full max-w-2xl space-y-8 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-8 shadow-2xl shadow-slate-950/20">
        <div class="text-center">
            <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Login</p>

        </div>

        <div class="rounded-[1.75rem] border border-slate-800/80 bg-slate-950/80 p-6 sm:p-8">
            <form asp-action="Login" method="post" class="space-y-6">
                @if (ViewBag.Error != null && ViewBag.Error == true)
                {
                    <div asp-validation-summary="All"
                         class="rounded-xl border border-rose-400/30 bg-rose-950/80 p-4 text-sm text-rose-200"></div>
                }
                <label class="space-y-2">
                    <span class="text-sm font-medium text-slate-200">Email address</span>
                    <input asp-for="Email"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="Email" class="text-sm text-rose-300"></span> <b></b>
                </label>

                <label class="space-y-2">
                    <span class="text-sm font-medium text-slate-200">Password</span>
                    <input asp-for="Password" type="password"
                           class="w-full rounded-2xl border border-slate-700/80 bg-slate-900 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" />
                    <span asp-validation-for="Password" class="text-sm text-rose-300"></span>
                </label>

                <div>
                    <label class="inline-flex items-center text-sm text-slate-400">
                        <input asp-for="RememberMe" type="checkbox"
                               class="rounded border-slate-700/80 bg-slate-900 text-cyan-500 focus:ring-cyan-500/20" />
                        <span class="ml-2">Remember me</span>
                    </label>
                </div>

                    
                <button type="submit"
                        class="cursor-pointer inline-flex w-full items-center justify-center rounded-full bg-cyan-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/80">Sign
                    in</button>
                </form>
            </div>

            <p class="text-center text-sm text-slate-400">Don't have an account? <a asp-action="Register"
                                                                                        asp-controller="Account" class="font-semibold text-white transition hover:text-cyan-300">Register</a>
            </p>
        </div>
    </div>