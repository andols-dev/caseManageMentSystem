@{
    ViewData["Title"] = "Logged Out";
}

<div class="min-h-[calc(100vh-6rem)] flex items-center justify-center py-12">
    <div
        class="w-full max-w-2xl space-y-8 rounded-[2rem] border border-slate-800/80 bg-slate-900/95 p-8 shadow-2xl shadow-slate-950/20">
        <div class="text-center">
            <p class="text-sm uppercase tracking-[0.32em] text-cyan-300">Logged Out</p>
            <h1 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">You have been logged out</h1>
            <p class="mx-auto mt-4 max-w-xl text-sm text-slate-400">Thank you for using the Case Management System. You
                have been successfully logged out.</p>
            </div>

            <div class="text-center">
                <a asp-action="Login" asp-controller="Account"
                       class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/80">Sign
                    in again</a>
                </div>
            </div>
        </div>
